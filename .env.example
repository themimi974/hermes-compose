# =============================================================================
# Hermes Agent — Environment Variables
# =============================================================================
# Copy to .hermes/.env and edit.
# The init-hermes.sh script will inject the active provider's API key.
# =============================================================================

# --- Provider Selection ------------------------------------------------------
# Set PROVIDER in your shell or .env before running init-hermes.sh:
#   PROVIDER=nvidia    (default)
#   PROVIDER=openai
#   PROVIDER=anthropic
#   PROVIDER=openrouter
#   PROVIDER=gemini
#   PROVIDER=ollama
#   PROVIDER=lmstudio
#   PROVIDER=local
#   PROVIDER=custom
# =============================================================================

# --- Provider API Keys (only the active provider's is needed) ---------------
# NVIDIA NIM (https://build.nvidia.com) — free tier available
NVIDIA_API_KEY=*** OpenAI API
OPENAI_API_KEY=*** Anthropic API
ANTHROPIC_API_KEY=*** OpenRouter (https://openrouter.ai)
OPENROUTER_API_KEY=*** Google Gemini (https://aistudio.google.com/apikey)
GOOGLE_API_KEY=*** HuggingFace token (for gated local models)
HF_TOKEN=*** Custom OpenAI-compatible endpoint
CUSTOM_BASE_URL=http://localhost:8000/v1
CUSTOM_API_KEY=*** --- Ollama-specific (only for PROVIDER=ollama) ----------------------------
# Host where Ollama is running (inside Docker)
OLLAMA_HOST=http://host.docker.internal:11434

# --- Model selection --------------------------------------------------------
# Model name (optional, falls back to provider defaults):
#   nvidia:     meta/llama-3.1-70b-instruct
#   openai:     gpt-4o
#   anthropic:  claude-sonnet-4-20250514
#   openrouter: meta-llama/llama-3.1-70b-instruct
#   gemini:     gemini-2.0-flash
#   ollama:     llama3.1
#   lmstudio:   local-model
#   local:      local
#   custom:     gpt-4o
MODEL=

# --- Web dashboard (optional, port 9119) ------------------------------------
# HERMES_DASHBOARD=1
# HERMES_DASHBOARD_INSECURE=0    # skip OAuth (local/dev only)

# --- OpenAI-compatible API server (optional, port 8642) ---------------------
# API_SERVER_ENABLED=true
# API_SERVER_KEY=your-secret-key-min-8-chars
# API_SERVER_HOST=0.0.0.0
# API_SERVER_CORS_ORIGINS=*

# --- SSH access (optional, set HERMES_SSH in init-hermes.sh) ---------------
# HERMES_SSH=none                # no SSH
# HERMES_SSH=~/.ssh              # full directory
# HERMES_SSH=~/.ssh/id_rsa       # single key
